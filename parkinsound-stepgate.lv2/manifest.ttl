@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://github.com/pilali/parkinsound/lv2/stepgate>
    a lv2:Plugin ;
    lv2:binary <stepgate.so> ;
    rdfs:seeAlso <stepgate.ttl> .

<Off.ttl>
    lv2:appliesTo <https://github.com/pilali/parkinsound/lv2/stepgate> ;
    a pset:Preset ;
    rdfs:seeAlso <Off.ttl> .

<Four_on_the_Floor.ttl>
    lv2:appliesTo <https://github.com/pilali/parkinsound/lv2/stepgate> ;
    a pset:Preset ;
    rdfs:seeAlso <Four_on_the_Floor.ttl> .

<Eighth_Notes.ttl>
    lv2:appliesTo <https://github.com/pilali/parkinsound/lv2/stepgate> ;
    a pset:Preset ;
    rdfs:seeAlso <Eighth_Notes.ttl> .

<Sixteenth_Chop.ttl>
    lv2:appliesTo <https://github.com/pilali/parkinsound/lv2/stepgate> ;
    a pset:Preset ;
    rdfs:seeAlso <Sixteenth_Chop.ttl> .
