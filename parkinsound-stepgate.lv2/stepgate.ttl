@prefix doap:   <http://usefulinc.com/ns/doap#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .
@prefix atom:   <http://lv2plug.in/ns/ext/atom#> .
@prefix urid:   <http://lv2plug.in/ns/ext/urid#> .
@prefix time:   <http://lv2plug.in/ns/ext/time#> .
@prefix units:  <http://lv2plug.in/ns/extensions/units#> .
@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

<https://github.com/pilali/parkinsound>
    a doap:Project ;
    doap:name "Parkinsound" .

<https://github.com/pilali/parkinsound/lv2/stepgate>
    a lv2:Plugin , lv2:FilterPlugin ;
    doap:name "Parkinsound Step Gate" ;
    doap:license <http://opensource.org/licenses/isc> ;
    lv2:project <https://github.com/pilali/parkinsound> ;
    lv2:minorVersion 2 ;
    lv2:microVersion 0 ;
    lv2:requiredFeature urid:map ;
    lv2:optionalFeature lv2:hardRTCapable ;

    lv2:port [
        a lv2:InputPort , atom:AtomPort ;
        atom:bufferType atom:Sequence ;
        atom:supports time:Position ;
        lv2:designation lv2:control ;
        lv2:index 0 ;
        lv2:symbol "time_in" ;
        lv2:name "Time" ;
    ] , [
        a lv2:AudioPort , lv2:InputPort ;
        lv2:index 1 ;
        lv2:symbol "audio_in_l" ;
        lv2:name "Audio In L" ;
    ] , [
        a lv2:AudioPort , lv2:InputPort ;
        lv2:index 2 ;
        lv2:symbol "audio_in_r" ;
        lv2:name "Audio In R" ;
    ] , [
        a lv2:AudioPort , lv2:OutputPort ;
        lv2:index 3 ;
        lv2:symbol "audio_out_l" ;
        lv2:name "Audio Out L" ;
    ] , [
        a lv2:AudioPort , lv2:OutputPort ;
        lv2:index 4 ;
        lv2:symbol "audio_out_r" ;
        lv2:name "Audio Out R" ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 5 ;
        lv2:symbol "sync_source" ;
        lv2:name "Sync Source" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:scalePoint [ rdfs:label "Host Sync" ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "Free Run"  ; rdf:value 1 ] ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 6 ;
        lv2:symbol "tempo" ;
        lv2:name "Tempo" ;
        lv2:default 120.0 ;
        lv2:minimum 20.0 ;
        lv2:maximum 300.0 ;
        units:unit units:bpm ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 7 ;
        lv2:symbol "division" ;
        lv2:name "Division" ;
        lv2:default 4 ;
        lv2:minimum 0 ;
        lv2:maximum 5 ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:scalePoint [ rdfs:label "1/1"  ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "1/2"  ; rdf:value 1 ] ;
        lv2:scalePoint [ rdfs:label "1/4"  ; rdf:value 2 ] ;
        lv2:scalePoint [ rdfs:label "1/8"  ; rdf:value 3 ] ;
        lv2:scalePoint [ rdfs:label "1/16" ; rdf:value 4 ] ;
        lv2:scalePoint [ rdfs:label "1/32" ; rdf:value 5 ] ;
    ] , [
        a lv2:ControlPort , lv2:OutputPort ;
        lv2:index 8 ;
        lv2:symbol "current_step" ;
        lv2:name "Current Step" ;
        lv2:minimum 1 ;
        lv2:maximum 16 ;
        lv2:portProperty lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 9 ;
        lv2:symbol "step_1_on" ;
        lv2:name "Step 1 On" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 10 ;
        lv2:symbol "step_1_tie" ;
        lv2:name "Step 1 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 11 ;
        lv2:symbol "step_2_on" ;
        lv2:name "Step 2 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 12 ;
        lv2:symbol "step_2_tie" ;
        lv2:name "Step 2 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 13 ;
        lv2:symbol "step_3_on" ;
        lv2:name "Step 3 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 14 ;
        lv2:symbol "step_3_tie" ;
        lv2:name "Step 3 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 15 ;
        lv2:symbol "step_4_on" ;
        lv2:name "Step 4 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 16 ;
        lv2:symbol "step_4_tie" ;
        lv2:name "Step 4 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 17 ;
        lv2:symbol "step_5_on" ;
        lv2:name "Step 5 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 18 ;
        lv2:symbol "step_5_tie" ;
        lv2:name "Step 5 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 19 ;
        lv2:symbol "step_6_on" ;
        lv2:name "Step 6 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 20 ;
        lv2:symbol "step_6_tie" ;
        lv2:name "Step 6 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 21 ;
        lv2:symbol "step_7_on" ;
        lv2:name "Step 7 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 22 ;
        lv2:symbol "step_7_tie" ;
        lv2:name "Step 7 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 23 ;
        lv2:symbol "step_8_on" ;
        lv2:name "Step 8 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 24 ;
        lv2:symbol "step_8_tie" ;
        lv2:name "Step 8 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 25 ;
        lv2:symbol "step_9_on" ;
        lv2:name "Step 9 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 26 ;
        lv2:symbol "step_9_tie" ;
        lv2:name "Step 9 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 27 ;
        lv2:symbol "step_10_on" ;
        lv2:name "Step 10 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 28 ;
        lv2:symbol "step_10_tie" ;
        lv2:name "Step 10 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 29 ;
        lv2:symbol "step_11_on" ;
        lv2:name "Step 11 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 30 ;
        lv2:symbol "step_11_tie" ;
        lv2:name "Step 11 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 31 ;
        lv2:symbol "step_12_on" ;
        lv2:name "Step 12 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 32 ;
        lv2:symbol "step_12_tie" ;
        lv2:name "Step 12 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 33 ;
        lv2:symbol "step_13_on" ;
        lv2:name "Step 13 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 34 ;
        lv2:symbol "step_13_tie" ;
        lv2:name "Step 13 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 35 ;
        lv2:symbol "step_14_on" ;
        lv2:name "Step 14 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 36 ;
        lv2:symbol "step_14_tie" ;
        lv2:name "Step 14 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 37 ;
        lv2:symbol "step_15_on" ;
        lv2:name "Step 15 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 38 ;
        lv2:symbol "step_15_tie" ;
        lv2:name "Step 15 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 39 ;
        lv2:symbol "step_16_on" ;
        lv2:name "Step 16 On" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 40 ;
        lv2:symbol "step_16_tie" ;
        lv2:name "Step 16 Tie" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 41 ;
        lv2:symbol "enabled" ;
        lv2:name "Enabled" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 42 ;
        lv2:symbol "depth" ;
        lv2:name "Depth" ;
        lv2:default 1.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0 ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 43 ;
        lv2:symbol "attack" ;
        lv2:name "Attack" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0 ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 44 ;
        lv2:symbol "decay" ;
        lv2:name "Decay" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0 ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 45 ;
        lv2:symbol "sustain" ;
        lv2:name "Sustain" ;
        lv2:default 1.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0 ;
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 46 ;
        lv2:symbol "release" ;
        lv2:name "Release" ;
        lv2:default 0.5 ; lv2:minimum 0.0 ; lv2:maximum 1.0 ;
    ] ;

    modgui:gui [
        a modgui:Gui ;
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate    <modgui/icon-parkinsound-stepgate.html> ;
        modgui:stylesheet      <modgui/stylesheet-parkinsound-stepgate.css> ;
        modgui:javascript      <modgui/javascript-parkinsound-stepgate.js> ;
        modgui:screenshot      <modgui/screenshot-parkinsound-stepgate.png> ;
        modgui:thumbnail       <modgui/thumbnail-parkinsound-stepgate.png> ;
        modgui:brand           "Parkinsound" ;
        modgui:label           "Step Gate" ;
        modgui:model           "" ;
        modgui:panel           "" ;
        modgui:color           "white" ;
        modgui:knob            "" ;
        modgui:monitoredOutputs [ lv2:symbol "current_step" ]
    ] .
