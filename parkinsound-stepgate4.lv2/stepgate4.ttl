@prefix doap:   <http://usefulinc.com/ns/doap#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .
@prefix atom:   <http://lv2plug.in/ns/ext/atom#> .
@prefix urid:   <http://lv2plug.in/ns/ext/urid#> .
@prefix time:   <http://lv2plug.in/ns/ext/time#> .
@prefix units:  <http://lv2plug.in/ns/extensions/units#> .
@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

<https://github.com/pilali/parkinsound>
    a doap:Project ;
    doap:name "Parkinsound" .

<https://github.com/pilali/parkinsound/lv2/stepgate4>
    a lv2:Plugin , lv2:FilterPlugin ;
    doap:name "Parkinsound Step Gate 4" ;
    doap:license <http://opensource.org/licenses/isc> ;
    lv2:project <https://github.com/pilali/parkinsound> ;
    lv2:minorVersion 1 ;
    lv2:microVersion 0 ;
    lv2:requiredFeature urid:map ;
    lv2:optionalFeature lv2:hardRTCapable ;
    lv2:port
    [
        a lv2:InputPort , atom:AtomPort ;
        atom:bufferType atom:Sequence ;
        atom:supports time:Position ;
        lv2:designation lv2:control ;
        lv2:index 0 ;
        lv2:symbol "time_in" ;
        lv2:name "Time" ;
    ] ,
    [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 1 ;
        lv2:symbol "sync_source" ;
        lv2:name "Sync Source" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:scalePoint [ rdfs:label "Host Sync" ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "Free Run" ; rdf:value 1 ] ;
    ] ,
    [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 2 ;
        lv2:symbol "tempo" ;
        lv2:name "Tempo" ;
        lv2:default 120.0 ; lv2:minimum 20.0 ; lv2:maximum 300.0 ;
        units:unit units:bpm ;
    ] ,
    [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 3 ;
        lv2:symbol "enabled" ;
        lv2:name "Enabled" ;
        lv2:default 1 ; lv2:minimum 0 ; lv2:maximum 1 ;
        lv2:portProperty lv2:toggled , lv2:integer , lv2:notOnGUI ;
    ] ,
    [
        a lv2:AudioPort , lv2:InputPort ;
        lv2:index 4 ;
        lv2:symbol "in_1" ;
        lv2:name "Audio In 1" ;
    ] ,
    [
        a lv2:AudioPort , lv2:InputPort ;
        lv2:index 5 ;
        lv2:symbol "in_2" ;
        lv2:name "Audio In 2" ;
    ] ,
    [
